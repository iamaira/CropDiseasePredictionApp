{
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "python app.py"
  },
  "env": {
    "GEMINI_API_KEY": {
      "fromSecret": "GEMINI_API_KEY"
    },
    "GOOGLE_API_KEY": {
      "fromSecret": "GOOGLE_API_KEY"
    }
  }
}
{
  "$schema": "https://railway.app/railway.schema.json",
  "deploy": {
    "startCommand": "gunicorn app:app --bind 0.0.0.0:$PORT"
  }
}